{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spectrelauncher",
  "version": "0.2.1",
  "identifier": "spectrerevival.spectrelauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "call populatebackend.bat && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "spectrelauncher",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "publisher": "SpectreRevival",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "assets/"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://spectrelauncher.ohmvir.dev/update/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1QzY5OERGNTJEODQ1NUEKUldSYVJkaFMzNWpHNWNoNjJlTmM2anR5RkR1TCtYQ28yWnkzM0tjVE0wdE5IV0tCQURJRGhIcWQK"
    }
  }
}
